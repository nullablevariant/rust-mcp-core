version: 1
server:
  host: 127.0.0.1
  port: 3000
  endpoint_path: /mcp
  logging:
    level: info
  transport:
    mode: streamable_http
  auth:
    enabled: false
upstreams:
  api:
    base_url: ${env:API_BASE_URL}
tools:
  items:
    - name: api.search
      description: Search upstream
      input_schema:
        type: object
        properties:
          query: { type: string }
        required: [query]
      execute:
        type: http
        upstream: api
        method: GET
        path: /search
        query:
          q: ${query}
