version: 1
server:
  host: 0.0.0.0
  port: 3000
  endpoint_path: /mcp
  logging:
    level: info
  transport:
    mode: streamable_http
  auth:
    enabled: false
tools:
  items:
    - name: noop
      description: No-op
      input_schema:
        type: object
      execute:
        type: http
        upstream: api
        method: GET
        path: /noop
upstreams:
  api:
    base_url: http://localhost
