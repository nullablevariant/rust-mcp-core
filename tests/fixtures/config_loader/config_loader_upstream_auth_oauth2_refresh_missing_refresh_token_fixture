version: 1
server:
  transport:
    mode: stdio
  auth:
    enabled: false
upstreams:
  api:
    base_url: https://example.com
    auth:
      type: oauth2
      grant: refresh_token
      token_url: https://auth.example.com/oauth/token
      client_id: example-client
      client_secret:
        source: inline
        value: super-secret
tools:
  items:
    - name: noop
      description: No-op
      input_schema:
        type: object
      execute:
        type: http
        upstream: api
        method: GET
        path: /