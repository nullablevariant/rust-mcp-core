version: 1
server:
  transport:
    mode: stdio
  auth:
    enabled: false
upstreams:
  api:
    base_url: https://example.com
    auth:
      type: oauth2
      grant: client_credentials
      token_url: https://auth.example.com/oauth/token
      client_id: example-client
      client_secret:
        source: inline
        value: super-secret
      auth_method: request_body
      scopes:
        - reports.read
      audience: https://example.com
      extra_token_params:
        resource: https://example.com
      refresh:
        skew_sec: 60
        retry_on_401_once: true
tools:
  items:
    - name: noop
      description: No-op
      input_schema:
        type: object
      execute:
        type: http
        upstream: api
        method: GET
        path: /
