version: 1
server:
  host: ${env:MCP_HOST}
  port: ${env:MCP_PORT}
  endpoint_path: /mcp
  logging:
    level: info
  transport:
    mode: streamable_http
  auth:
    providers:
      - name: static
        type: bearer
        token: ${env:MCP_BEARER_TOKEN}
upstreams:
  api:
    base_url: ${env:API_BASE_URL}
tools:
  items:
    - name: api.ping
      description: Ping upstream
      input_schema:
        type: object
      execute:
        type: http
        upstream: api
        method: GET
        path: /ping
