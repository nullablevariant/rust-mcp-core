version: 1
server:
  host: 0.0.0.0
  port: 3000
  endpoint_path: /mcp
  logging:
    level: info
  transport:
    mode: streamable_http
  auth:
    enabled: false
upstreams:
  api:
    base_url: "http://example.com"
    auth:
      type: none
tools:
  items:
    - name: api.rich
      description: rich
      input_schema:
        type: object
      execute:
        type: http
        upstream: api
        method: GET
        path: /rich
      response:
        type: content
        items:
          - type: text
            text: "hello"
            annotations:
              audience: [user]
              priority: 0.9
              last_modified: "2025-01-01T00:00:00Z"
          - type: image
            data: "aW1hZ2U="
            mime_type: image/png
          - type: audio
            data: "YXVkaW8="
            mime_type: audio/wav
          - type: resource_link
            uri: "file:///tmp/data.txt"
            name: source
            mime_type: text/plain
            icons:
              - src: https://example.com/icon.png
                mime_type: image/png
          - type: resource
            resource:
              uri: "file:///tmp/data.txt"
              mime_type: text/plain
              text: "resource text"
              annotations:
                audience: [assistant]
                priority: 0.6
