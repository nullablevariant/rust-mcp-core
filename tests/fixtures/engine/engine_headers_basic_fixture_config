version: 1
server:
  host: 0.0.0.0
  port: 3000
  endpoint_path: /mcp
  logging:
    level: info
  transport:
    mode: streamable_http
  auth:
    enabled: false
outbound_http:
  user_agent: "mcp-test"
  headers:
    X-Default: "yes"
upstreams:
  api:
    base_url: "http://example.com"
    headers:
      X-Upstream: "ok"
    auth:
      type: basic
      username: "user"
      password: "pass"
tools:
  items:
    - name: api.headers
      description: headers
      input_schema:
        type: object
      execute:
        type: http
        upstream: api
        method: GET
        path: /headers
        headers:
          X-Tool: "tool"
