version: 1
server:
  host: 0.0.0.0
  port: 3000
  endpoint_path: /mcp
  logging:
    level: info
  transport:
    mode: streamable_http
  auth:
    enabled: false
upstreams:
  api:
    base_url: "http://example.com"
    auth:
      type: bearer
      token: "secret"
tools:
  items:
    - name: api.bearer
      description: bearer
      input_schema:
        type: object
      execute:
        type: http
        upstream: api
        method: GET
        path: /bearer
