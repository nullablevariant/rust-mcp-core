version: 1
server:
  host: 0.0.0.0
  port: 3000
  endpoint_path: /mcp
  logging:
    level: info
  transport:
    mode: streamable_http
  auth:
    enabled: false
outbound_http:
  timeout_ms: 1000
tools:
  items:
    - name: api.fallback
      description: Fallback
      input_schema:
        type: object
      execute:
        type: http
        upstream: api
        method: GET
        path: /fallback
      response:
        type: structured
        fallback: json_text
upstreams:
  api:
    base_url: http://localhost
