version: 1
server:
  host: 0.0.0.0
  port: 3000
  endpoint_path: /mcp
  logging:
    level: info
  transport:
    mode: streamable_http
  auth:
    enabled: false
tools:
  items:
    - name: tool.meta
      title: Meta Tool
      description: Meta
      input_schema:
        type: object
      output_schema:
        type: object
        properties:
          ok:
            type: boolean
      annotations:
        readOnlyHint: true
      icons:
        - src: "https://example.com/icon.png"
          mime_type: "image/png"
          sizes: ["48x48"]
      _meta:
        source: config
      execute:
        type: http
        upstream: api
        method: GET
        path: /