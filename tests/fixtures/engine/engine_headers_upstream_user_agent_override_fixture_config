version: 1
server:
  host: 0.0.0.0
  port: 3000
  endpoint_path: /mcp
  logging:
    level: info
  transport:
    mode: streamable_http
  auth:
    enabled: false
outbound_http:
  user_agent: "global-agent"
upstreams:
  api:
    base_url: "http://example.com"
    user_agent: "upstream-agent"
tools:
  items:
    - name: api.headers.ua
      description: headers ua override
      input_schema:
        type: object
      execute:
        type: http
        upstream: api
        method: GET
        path: /headers-ua
