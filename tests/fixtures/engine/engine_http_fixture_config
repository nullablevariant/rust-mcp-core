version: 1
server:
  host: 0.0.0.0
  port: 3000
  endpoint_path: /mcp
  logging:
    level: info
  transport:
    mode: streamable_http
  auth:
    enabled: false
upstreams:
  api:
    base_url: http://localhost
tools:
  items:
    - name: api.list
      description: List items
      input_schema:
        type: object
        properties:
          query:
            type: string
      execute:
        type: http
        upstream: api
        method: GET
        path: /items
        query:
          q: "alpha"
      response:
        type: structured
        template:
          items:
            - id: 1
        fallback: text
