config:
  version: 1
  server:
    host: 0.0.0.0
    port: 3000
    endpoint_path: /mcp
    logging:
      level: info
    transport:
      mode: streamable_http
    auth:
      enabled: false
  upstreams:
    api:
      base_url: "http://example.com"
      auth:
        type: none
  tools:
    items:
      - name: api.bad_content
        description: bad content
        input_schema:
          type: object
        execute:
          type: http
          upstream: api
          method: GET
          path: /bad-content
        response:
          type: content
          items:
            - "this should fail"
tool: api.bad_content
args: {}
