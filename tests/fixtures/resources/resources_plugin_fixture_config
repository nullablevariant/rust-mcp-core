version: 1
server:
  host: 127.0.0.1
  port: 3000
  endpoint_path: /mcp
  logging:
    level: info
  transport:
    mode: streamable_http
  auth:
    enabled: false
resources:
  notify_list_changed: true
  clients_can_subscribe: true
  providers:
    - type: plugin
      plugin: resource.plugin
      config:
        timeout: 2
      templates:
        - uri_template: resource://plugin/{path}
          name: plugin-template
          arguments_schema:
            type: object
            properties:
              path:
                type: string
            required: [path]
          completions:
            path: fs_paths
upstreams: {}
tools:
  enabled: false
  items: []
plugins:
  - name: resource.plugin
    type: resource
    config:
      region: us
      timeout: 1
